#!/bin/bash
# Copia questo file in start.sh e sostituisci i placeholder con i valori reali.
# start.sh è in .gitignore e non viene mai committato.

cd "$(dirname "$0")"
source venv/bin/activate

export STRIPE_SECRET_KEY="sk_live_INSERISCI_QUI_LA_TUA_CHIAVE"
